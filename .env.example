# ─────────────────────────────────────────────────────────────────────────────
# DTC CRM — environment variables
#
# Copy this file to `.env` and fill in the values:
#   cp .env.example .env        (macOS/Linux)
#   Copy-Item .env.example .env (Windows PowerShell)
#
# All of these are read server-side only (never exposed to the browser).
# Each integration degrades gracefully: if its vars are missing, that feature
# simply returns no data instead of crashing the app.
# ─────────────────────────────────────────────────────────────────────────────

# ── Asana ────────────────────────────────────────────────────────────────────
# Personal Access Token. Create one in Asana:
#   Settings → Apps → Developer apps → Personal access tokens → Create new token
ASANA_ACCESS_TOKEN=

# Project GIDs. Find a GID in the project's URL:
#   https://app.asana.com/0/<PROJECT_GID>/list
# Portfolio-companies project (one task per portfolio company).
ASANA_PORTCO_PROJECT_GID=
# Events project (one task per event).
ASANA_EVENTS_PROJECT_GID=
# Activity Tracking projects (one task per BD / GTM activity). Surfaced on the
# matching Contact and PortCo detail records.
ASANA_BD_PROJECT_GID=
ASANA_GTM_PROJECT_GID=

# ── Google Sheets ────────────────────────────────────────────────────────────
# OAuth 2.0 credentials for a Google Cloud project with the Sheets API enabled.
# Create them under: APIs & Services → Credentials → OAuth client ID.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Long-lived refresh token obtained via the OAuth consent flow.
GOOGLE_REFRESH_TOKEN=
# The spreadsheet ID from its URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=

# ── Gemini / Vertex AI (LLM: email drafts, signal scans, query) ───────────────
# The app calls Gemini on Vertex AI under this Google Cloud project + location.
GOOGLE_CLOUD_PROJECT=
GEMINI_LOCATION=us-central1
# Auth = Application Default Credentials. STRONGLY RECOMMENDED: point this at a
# service-account JSON key (IAM role "Vertex AI User"). Service accounts are NOT
# subject to Workspace reauth policies, so this avoids the recurring
# "invalid_grant / invalid_rapt" reauth errors you get with
# `gcloud auth application-default login`. Leave blank to fall back to gcloud ADC.
GOOGLE_APPLICATION_CREDENTIALS=

# ── Apollo ───────────────────────────────────────────────────────────────────
# Apollo.io API key for contact enrichment.
# Generate under: Settings → Integrations → API in your Apollo account.
APOLLO_API_KEY=

# ── Sumble ───────────────────────────────────────────────────────────────────
# Sumble company / technographic / org-intelligence API.
# Generate a key at: sumble.com/account/api-keys
# Credit-metered; leave blank to disable Sumble features (they degrade gracefully).
SUMBLE_API_KEY=

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# Claude API key for AI email drafting and the Signal Radar news scan.
# Generate at: console.anthropic.com → API keys
ANTHROPIC_API_KEY=

# ── Python backend (backend/) ────────────────────────────────────────────────
# Only used by the optional FastAPI backend in `backend/` — the TypeScript
# frontend ignores this. Comma-separated list of browser origins allowed to call
# the API (CORS). Set this to wherever the frontend is served from.
# Defaults to the common Vite/dev ports if left unset.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
