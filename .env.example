# ── News (Event Registry / NewsAPI.ai) ───────────────────────────────────────
# Real, durable article links for the Signals scan. Key from eventregistry.org
# (a.k.a. newsapi.ai) — keys are UUIDs. NOT newsapi.org.
# When set, the scan grounds Gemini on real recent articles for your portcos +
# network companies (each signal cites the exact article URL). Leave blank to fall
# back to Gemini's Google Search grounding (source links become a web search).
# Free tier = 2,000 tokens; getArticles requests are batched/capped to conserve them.
NEWSAPI_KEY=c51273d6-4002-4460-9349-ca22928e98f7

# ── Google Gemini (Vertex AI) ────────────────────────────────────────────────
# Powers email drafting, the Signals scan (Google Search grounding + PDF context),
# AI insights, and the LLM Query agent. Runs on VERTEX AI under our Google Cloud
# project (enterprise path) — NOT an AI Studio API key. Model: gemini-2.5-flash.
#   GOOGLE_CLOUD_PROJECT — the GCP project id (Vertex AI API enabled + billing)
#   GEMINI_LOCATION      — region (default us-central1)
# Auth = Application Default Credentials. For local dev run:
#   gcloud auth application-default login
# OR point GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON key with the
# "Vertex AI User" role. Leave GOOGLE_CLOUD_PROJECT blank to disable AI features.
GOOGLE_CLOUD_PROJECT=venture-pulse-499913
GEMINI_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=C:/Users/Dell AI User/Downloads/DTC_CRM_Local/sa-key.json

# ── LinkedIn (Marketing / Community Management API) ──────────────────────────
# Official API ONLY — exposes your own company page's posts + analytics. There is
# NO LinkedIn API for the general home feed or other people's posts/profiles.
# Setup: create a LinkedIn app, get the "Community Management API" product approved,
# then authorize an OAuth 2.0 token with the r_organization_social scope.
#   LINKEDIN_ACCESS_TOKEN — OAuth access token (member-authorized, 3-legged)
#   LINKEDIN_ORG_ID        — numeric org id only (the N in urn:li:organization:N)
#   LINKEDIN_ORG_NAME      — display name shown in the UI (optional)
#   LINKEDIN_API_VERSION   — versioned-API month, format YYYYMM (optional; default below)
# CLIENT_ID/CLIENT_SECRET are only used by mint-linkedin-token.mjs to generate the
# ACCESS_TOKEN below; the app itself authenticates with ACCESS_TOKEN.
# Leave ACCESS_TOKEN/ORG_ID blank to disable LinkedIn features (they degrade gracefully).
LINKEDIN_CLIENT_ID=788kj24uwqscif
LINKEDIN_CLIENT_SECRET=WPL_AP1.cqo6UwDjZikxYVe0.FssNHg==
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=
LINKEDIN_ORG_NAME=
LINKEDIN_API_VERSION=

